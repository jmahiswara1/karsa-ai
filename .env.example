# Service auth 
# Token yang dipakai backend untuk hit endpoint AI ini.
AI_SERVICE_TOKEN=your-service-token

# Active provider + fallback order 
# ACTIVE_PROVIDER adalah provider yang dicoba pertama.
# Kalau gagal (network/rate limit), otomatis lanjut ke FALLBACK_ORDER.
ACTIVE_PROVIDER=sumopod
FALLBACK_ORDER=sumopod,deepseek,bai

# b.ai (https://api.b.ai/v1)
# Model default DeepSeek-V4-Pro tersedia di sini.
BAI_BASE_URL=https://api.b.ai/v1
BAI_API_KEY=sk-your-bai-api-key
BAI_MODEL=DeepSeek-V4-Pro

# DeepSeek (direct, opsional)
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_MODEL=DeepSeek-V4-Pro

# Sumopod 
SUMOPOD_BASE_URL=https://ai.sumopod.com/v1
SUMOPOD_API_KEY=sk-your-sumopod-api-key
SUMOPOD_MODEL=
SUMOPOD_FALLBACK_MODEL=
